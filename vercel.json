{
	"headers": [
		{
			"source": "/build/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, s-maxage=31536000, immutable"
				}
			]
		},
		{
			"source": "/assets/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, s-maxage=31536000, immutable"
				}
			]
		},
		{
			"source": "/(.*\\.(js|css|svg|png|jpg|jpeg|webp|avif|json|woff2|woff|ttf))",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, s-maxage=31536000, immutable"
				}
			]
		},
		{
			"source": "/favicon.ico",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, s-maxage=31536000, immutable"
				}
			]
		}
	]
}
